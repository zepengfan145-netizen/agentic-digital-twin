{
  "name": "agentic-digital-twin",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "An open-source agentic digital twin workbench with a browser-based robotic arm demo.",
  "license": "MIT",
  "keywords": ["digital-twin", "agentic-ai", "robotics", "threejs", "simulation", "manufacturing"],
  "homepage": "https://agentic-digital-twin.vercel.app",
  "files": ["dist/", "src/", "docs/", "examples/", "skills/", "public/", "index.html", "README.md", "LICENSE", "CHANGELOG.md", "CONTRIBUTING.md", "SECURITY.md"],
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 4188",
